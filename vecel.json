{
    "version": 2,
    "builds": [
      { "src": "/front", "use": "@vercel/static" },
      { "src": "/back", "use": "@vercel/node" }
    ],
    "routes": [
      { "handle": "filesystem" },
      { "src": "/usuario", "dest": "/Back/server.js" },
      { "src": "/", "dest": "/front/index.html" }
    ]
  }
  